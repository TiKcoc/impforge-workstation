{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "ImpForge default capabilities for AI orchestration",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:allow-execute",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-load",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-request-permission",
    "os:default",
    "fs:default",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-stat",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME" },
        { "path": "$APPDATA/**" },
        { "path": "$APPDATA" }
      ]
    }
  ]
}
