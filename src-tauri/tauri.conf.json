{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ImpForge",
  "version": "0.6.0",
  "identifier": "com.aiimp.impforge",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "ImpForge — AI Workstation Builder",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* ws://localhost:* https://*.anthropic.com https://*.openai.com https://api.github.com https://openrouter.ai https://huggingface.co https://*.huggingface.co; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; font-src 'self' data:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Your complete AI stack. One desktop app.",
    "longDescription": "ImpForge AI Workstation — Chat with 28+ free AI models, manage Docker containers, orchestrate agents, automate workflows, and write code.",
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libappindicator3-1",
          "librsvg2-2"
        ],
        "section": "devel"
      }
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "entitlements": null
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "docker",
          "cmd": "docker",
          "args": true
        },
        {
          "name": "git",
          "cmd": "git",
          "args": true
        },
        {
          "name": "gh",
          "cmd": "gh",
          "args": true
        }
      ]
    },
    "store": {
      "path": ".impforge-store.json"
    },
    "notification": {
      "all": true
    }
  }
}
